<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hospital_report_config_form" model="ir.ui.view">
        <field name="name">hospital.report.config.form</field>
        <field name="model">hospital.report.config</field>
        <field name="arch" type="xml">
            <form string="Report Branding">
                <sheet>
                    <div class="o-hms-form-header">
                        <div class="o-hms-avatar">
                            <i class="fa fa-paint-brush"/>
                        </div>
                        <div class="oe_title">
                            <label for="company_id"/>
                            <h1>
                                <field name="company_id" readonly="1"/>
                            </h1>
                        </div>
                    </div>
                    <group string="Logo &amp; Colours" class="o-hms-card-group">
                        <field name="logo" widget="image" options="{'size': [128, 128]}"/>
                        <field name="primary_color"/>
                    </group>
                    <group string="Header / Footer Text" class="o-hms-card-group">
                        <field name="header_text"/>
                        <field name="footer_text"/>
                    </group>
                    <group string="Display Options" class="o-hms-card-group">
                        <field name="show_company_address"/>
                        <field name="show_patient_photo"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hospital_report_config_list" model="ir.ui.view">
        <field name="name">hospital.report.config.list</field>
        <field name="model">hospital.report.config</field>
        <field name="arch" type="xml">
            <list string="Report Branding Configs">
                <field name="company_id"/>
                <field name="header_text"/>
                <field name="primary_color"/>
                <field name="show_company_address"/>
            </list>
        </field>
    </record>

    <record id="action_hospital_report_config" model="ir.actions.act_window">
        <field name="name">Report Branding</field>
        <field name="res_model">hospital.report.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No report branding configuration yet.
            </p>
            <p>
                Create one to customise the logo, colours, and text used across
                all hospital printed reports.
            </p>
        </field>
    </record>

</odoo>
