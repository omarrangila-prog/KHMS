<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hospital_census_wizard_form" model="ir.ui.view">
        <field name="name">hospital.census.wizard.form</field>
        <field name="model">hospital.census.wizard</field>
        <field name="arch" type="xml">
            <form string="Daily Census Report">
                <group class="o-hms-card-group">
                    <field name="company_id"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button name="action_print_census"
                            string="Print Census"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hospital_census_wizard" model="ir.actions.act_window">
        <field name="name">Daily Census Report</field>
        <field name="res_model">hospital.census.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Patient Visit History: direct action on hospital.patient to trigger
         per-patient visit history report from the patient form. -->
    <record id="action_hospital_patient_visit_history_wizard" model="ir.actions.act_window">
        <field name="name">Patient Visit History</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Select a patient to print their visit history report.
            </p>
        </field>
    </record>

</odoo>
