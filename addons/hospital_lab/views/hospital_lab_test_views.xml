<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Lab Test: List view -->
    <record id="hospital_lab_test_view_list" model="ir.ui.view">
        <field name="name">hospital.lab.test.list</field>
        <field name="model">hospital.lab.test</field>
        <field name="arch" type="xml">
            <list string="Lab Tests">
                <field name="name"/>
                <field name="code"/>
                <field name="sample_type"/>
                <field name="normal_range_min"/>
                <field name="normal_range_max"/>
                <field name="price"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Lab Test: Form view -->
    <record id="hospital_lab_test_view_form" model="ir.ui.view">
        <field name="name">hospital.lab.test.form</field>
        <field name="model">hospital.lab.test</field>
        <field name="arch" type="xml">
            <form string="Lab Test">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Test Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="sample_type"/>
                            <field name="price"/>
                        </group>
                        <group>
                            <field name="normal_range_min"/>
                            <field name="normal_range_max"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Billing">
                        <field name="product_id"/>
                    </group>
                    <group string="Description / Instructions">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Lab Test: Search view -->
    <record id="hospital_lab_test_view_search" model="ir.ui.view">
        <field name="name">hospital.lab.test.search</field>
        <field name="model">hospital.lab.test</field>
        <field name="arch" type="xml">
            <search string="Search Lab Tests">
                <field name="name"/>
                <field name="code"/>
                <filter string="Blood Tests" name="filter_blood"
                        domain="[('sample_type', '=', 'blood')]"/>
                <filter string="Urine Tests" name="filter_urine"
                        domain="[('sample_type', '=', 'urine')]"/>
                <filter string="Archived" name="inactive"
                        domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Sample Type" name="group_sample_type"
                            context="{'group_by': 'sample_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action: Lab Test Catalog -->
    <record id="action_hospital_lab_test" model="ir.actions.act_window">
        <field name="name">Lab Test Catalog</field>
        <field name="res_model">hospital.lab.test</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hospital_lab_test_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first lab test to the catalog.
            </p>
        </field>
    </record>

</odoo>
