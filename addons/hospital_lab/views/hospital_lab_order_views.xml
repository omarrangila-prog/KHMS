<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Lab Order: List view (the primary Lab Dashboard queue) -->
    <record id="hospital_lab_order_view_list" model="ir.ui.view">
        <field name="name">hospital.lab.order.list</field>
        <field name="model">hospital.lab.order</field>
        <field name="arch" type="xml">
            <list string="Lab Orders"
                  default_order="priority desc, create_date asc"
                  decoration-danger="state == 'cancelled'"
                  decoration-success="state == 'completed'"
                  decoration-warning="priority in ('urgent', 'emergency')">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="test_id"/>
                <field name="doctor_id"/>
                <field name="priority"
                       widget="badge"
                       decoration-danger="priority == 'emergency'"
                       decoration-warning="priority == 'urgent'"
                       decoration-info="priority == 'normal'"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state == 'completed'"
                       decoration-danger="state == 'cancelled'"
                       decoration-warning="state == 'processing'"
                       decoration-info="state in ('ordered', 'sample_collected')"/>
                <field name="collected_at"/>
                <field name="company_id" column_invisible="True"/>
                <button name="action_collect_sample" type="object"
                        string="Collect Sample"
                        icon="fa-flask"
                        invisible="state != 'ordered'"/>
                <button name="action_processing" type="object"
                        string="Start Processing"
                        icon="fa-cogs"
                        invisible="state != 'sample_collected'"/>
                <button name="action_complete" type="object"
                        string="Complete"
                        icon="fa-check"
                        invisible="state != 'processing'"/>
            </list>
        </field>
    </record>

    <!-- Lab Order: Form view -->
    <record id="hospital_lab_order_view_form" model="ir.ui.view">
        <field name="name">hospital.lab.order.form</field>
        <field name="model">hospital.lab.order</field>
        <field name="arch" type="xml">
            <form string="Lab Order">
                <header>
                    <button name="action_collect_sample" type="object"
                            string="Mark Sample Collected"
                            class="btn-primary"
                            invisible="state != 'ordered'"/>
                    <button name="action_processing" type="object"
                            string="Start Processing"
                            class="btn-primary"
                            invisible="state != 'sample_collected'"/>
                    <button name="action_complete" type="object"
                            string="Mark Completed"
                            class="btn-primary"
                            invisible="state != 'processing'"/>
                    <button name="action_cancel_wizard" type="object"
                            string="Cancel"
                            class="btn-secondary"
                            invisible="state in ('completed', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="ordered,sample_collected,processing,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Order Details">
                            <field name="visit_id"/>
                            <field name="patient_id" readonly="1"/>
                            <field name="doctor_id"/>
                            <field name="test_id"/>
                            <field name="priority"/>
                        </group>
                        <group string="Sample Collection">
                            <field name="sample_barcode"/>
                            <field name="collected_by" readonly="1"/>
                            <field name="collected_at" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Cancellation" invisible="state != 'cancelled'">
                        <field name="cancel_reason" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Results" name="results">
                            <field name="result_ids">
                                <list editable="bottom"
                                      decoration-danger="is_abnormal == True">
                                    <field name="parameter_name"/>
                                    <field name="value"/>
                                    <field name="unit"/>
                                    <field name="normal_range_min"/>
                                    <field name="normal_range_max"/>
                                    <field name="is_abnormal" readonly="1"
                                           widget="boolean"/>
                                    <field name="verified_by"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Lab Order: Kanban view -->
    <record id="hospital_lab_order_view_kanban" model="ir.ui.view">
        <field name="name">hospital.lab.order.kanban</field>
        <field name="model">hospital.lab.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="test_id"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="collected_at"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_top">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                            </div>
                            <field name="priority" widget="priority"/>
                        </div>
                        <div>
                            <field name="patient_id"/>
                        </div>
                        <div>
                            <field name="test_id"/>
                        </div>
                        <div>
                            <field name="state" widget="badge"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Lab Order: Search view -->
    <record id="hospital_lab_order_view_search" model="ir.ui.view">
        <field name="name">hospital.lab.order.search</field>
        <field name="model">hospital.lab.order</field>
        <field name="arch" type="xml">
            <search string="Search Lab Orders">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="test_id"/>
                <field name="doctor_id"/>
                <filter string="Ordered" name="filter_ordered"
                        domain="[('state', '=', 'ordered')]"/>
                <filter string="Sample Collected" name="filter_sample_collected"
                        domain="[('state', '=', 'sample_collected')]"/>
                <filter string="Processing" name="filter_processing"
                        domain="[('state', '=', 'processing')]"/>
                <filter string="Completed" name="filter_completed"
                        domain="[('state', '=', 'completed')]"/>
                <filter string="Cancelled" name="filter_cancelled"
                        domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Urgent / Emergency" name="filter_urgent"
                        domain="[('priority', 'in', ['urgent', 'emergency'])]"/>
                <filter string="Pending" name="filter_pending"
                        domain="[('state', 'not in', ['completed', 'cancelled'])]"/>
                <group expand="0" string="Group By">
                    <filter string="Priority" name="group_priority"
                            context="{'group_by': 'priority'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Test" name="group_test"
                            context="{'group_by': 'test_id'}"/>
                    <filter string="Doctor" name="group_doctor"
                            context="{'group_by': 'doctor_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action: Lab Order Queue -->
    <record id="action_hospital_lab_order" model="ir.actions.act_window">
        <field name="name">Lab Order Queue</field>
        <field name="res_model">hospital.lab.order</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="hospital_lab_order_view_search"/>
        <field name="context">{'search_default_filter_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No pending lab orders.
            </p>
        </field>
    </record>

    <!-- Action: Cancel wizard (launched from form button) -->
    <record id="action_hospital_lab_order_cancel_wizard" model="ir.actions.act_window">
        <field name="name">Cancel Lab Order</field>
        <field name="res_model">hospital.lab.order.cancel.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_hospital_lab_order"/>
        <field name="binding_view_types">form</field>
    </record>

</odoo>
