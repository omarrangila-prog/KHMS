<?xml version="1.0" encoding="utf-8"?>
<!-- 15 demo lab orders referencing real xml-ids from hospital_base and
     hospital_reception demo data. Visits used: 01 (amended to have lab
     requested), 03 (prescribe+lab), 07 (radiology only — lab added here
     as additional order for demo coverage), 08 (lab+radiology), and
     additional visits 02, 06, 09, 10.

     XML-IDs used from upstream modules:
       hospital_reception.demo_visit_01  (patient: hospital_base.demo_patient_01)
       hospital_reception.demo_visit_02  (patient: hospital_base.demo_patient_02)
       hospital_reception.demo_visit_03  (patient: hospital_base.demo_patient_03)
       hospital_reception.demo_visit_06  (patient: hospital_base.demo_patient_06)
       hospital_reception.demo_visit_07  (patient: hospital_base.demo_patient_07)
       hospital_reception.demo_visit_08
       hospital_reception.demo_visit_09
       hospital_reception.demo_visit_10
       hospital_base.demo_doctor_1 … demo_doctor_5
-->
<odoo noupdate="1">

    <!-- 1. CBC ordered for visit_03 (fever of unknown origin), state=ordered -->
    <record id="demo_lab_order_01" model="hospital.lab.order">
        <field name="visit_id" ref="hospital_reception.demo_visit_03"/>
        <field name="doctor_id" ref="hospital_base.demo_doctor_3"/>
        <field name="test_id" ref="hospital_lab.lab_test_cbc"/>
        <field name="state">ordered</field>
        <field name="priority">urgent</field>
    </record>

    <!-- 2. FBS ordered for visit_02 (hypertension, check metabolic profile), state=ordered -->
    <record id="demo_lab_order_02" model="hospital.lab.order">
        <field name="visit_id" ref="hospital_reception.demo_visit_02"/>
        <field name="doctor_id" ref="hospital_base.demo_doctor_2"/>
        <field name="test_id" ref="hospital_lab.lab_test_fbs"/>
        <field name="state">ordered</field>
        <field name="priority">normal</field>
    </record>

