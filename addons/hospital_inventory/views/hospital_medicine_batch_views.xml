<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- hospital.medicine.batch is stock.lot itself (_inherit, see
         models/hospital_medicine_batch.py) — these are view-inheritance
         additions onto Odoo's native Lots/Serial Numbers screens, adding
         only the expiry_date/is_expiring_soon/is_expired fields this
         module contributes. -->
    <record id="view_production_lot_form_inherit_hospital_inventory" model="ir.ui.view">
        <field name="name">stock.lot.view.form.inherit.hospital.inventory</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">
            <group name="inventory_group" position="inside">
                <field name="expiry_date"/>
                <field name="is_expiring_soon" widget="boolean_toggle" readonly="1"/>
                <field name="is_expired" widget="boolean_toggle" readonly="1"/>
            </group>
        </field>
    </record>

    <record id="view_production_lot_tree_inherit_hospital_inventory" model="ir.ui.view">
        <field name="name">stock.lot.view.list.inherit.hospital.inventory</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_tree"/>
        <field name="arch" type="xml">
            <field name="product_id" position="after">
                <field name="expiry_date" optional="show"/>
                <field name="is_expiring_soon" optional="show" widget="boolean_toggle"/>
                <field name="is_expired" optional="show" widget="boolean_toggle"/>
            </field>
        </field>
    </record>

    <record id="hospital_medicine_batch_view_search_expiring" model="ir.ui.view">
        <field name="name">stock.lot.view.search.hospital.inventory.expiring</field>
        <field name="model">stock.lot</field>
        <field name="arch" type="xml">
            <search string="Expiry Alerts">
                <field name="name"/>
                <field name="product_id"/>
                <filter string="Expiring Soon" name="filter_expiring_soon" domain="[('is_expiring_soon', '=', True)]"/>
                <filter string="Expired" name="filter_expired" domain="[('is_expired', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Medicine" name="group_by_product" context="{'group_by': 'product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hospital_medicine_batch_action_expiring" model="ir.actions.act_window">
        <field name="name">Expiry Alerts</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hospital_medicine_batch_view_search_expiring"/>
        <field name="domain">[("product_id.is_hospital_medicine", "=", True), "|", ("is_expiring_soon", "=", True), ("is_expired", "=", True)]</field>
        <field name="context">{'search_default_filter_expiring_soon': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No expiry alerts. All medicine batches are within their safe shelf life.
            </p>
        </field>
    </record>

</odoo>
