<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- ExpiryAlertService (Phase 6 §6): daily check for medicine batches
         entering the 30-day expiry window. Implemented as a model method
         on hospital.medicine.batch (= stock.lot, _inherit) rather than a
         literal "service class" — Odoo has no service-class pattern;
         ir.cron + a model method is the idiomatic equivalent. -->
    <record id="ir_cron_hospital_expiry_alert" model="ir.cron">
        <field name="name">Hospital Inventory: Expiry Alert Service</field>
        <field name="model_id" ref="model_stock_lot"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_expiring_batches()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

    <!-- LowStockAlertService (Phase 6 §6): daily check against the
         hospital.inventory.dashboard SQL view for medicines at/under
         reorder_threshold. -->
    <record id="ir_cron_hospital_low_stock_alert" model="ir.cron">
        <field name="name">Hospital Inventory: Low-Stock Alert Service</field>
        <field name="model_id" ref="model_product_template"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_low_stock()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

</odoo>
