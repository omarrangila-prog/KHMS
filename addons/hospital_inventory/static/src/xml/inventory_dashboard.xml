<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="hospital_inventory.InventoryDashboard">
        <div class="o_hospital_inventory_dashboard">

            <!-- Header -->
            <div class="o_hospital_dashboard_header">
                <div class="o_hospital_header_left">
                    <div class="o_hospital_header_icon" data-hms-tooltip="Medicine inventory">
                        <i class="fa fa-flask"/>
                    </div>
                    <h2>
                        Inventory
                        <small>Stock levels &#38; expiry alerts</small>
                    </h2>
                </div>
            </div>

            <!-- Error -->
            <div class="o_hospital_dashboard_error alert alert-danger"
                 t-if="state.error" role="alert"
                 style="display:flex;align-items:center;gap:8px;border-radius:14px;margin-bottom:20px">
                <i class="fa fa-exclamation-triangle"/>
                Couldn&#39;t load the dashboard.
                <button class="btn btn-link p-0 ms-2" t-on-click="onRetry">Retry</button>
            </div>

            <!-- KPI skeleton -->
            <div class="o_hospital_inventory_kpi_row o_hospital_skeleton"
                 style="min-height:110px" t-if="state.loading"/>

            <!-- KPI row -->
            <div class="o_hospital_inventory_kpi_row" t-if="!state.loading">

                <div class="o_hospital_inventory_kpi_card o_hospital_kpi_warning"
                     t-on-click="openLowStockAlerts"
                     data-hms-tooltip="View low-stock medicines">
                    <div class="o_hospital_kpi_icon"><i class="fa fa-exclamation-triangle"/></div>
                    <div class="o_hospital_kpi_value o-hms-kpi-animated"
                         data-kpi="low_stock"
                         t-esc="state.lowStockCount"/>
                    <div class="o_hospital_kpi_label">Low Stock</div>
                </div>

                <div class="o_hospital_inventory_kpi_card o_hospital_kpi_danger"
                     t-on-click="openExpiryAlerts"
                     data-hms-tooltip="View expiring or expired batches">
                    <div class="o_hospital_kpi_icon"><i class="fa fa-calendar-times-o"/></div>
                    <div class="o_hospital_kpi_value o-hms-kpi-animated"
                         data-kpi="expiring_soon"
                         t-esc="state.expiringSoonCount"/>
                    <div class="o_hospital_kpi_label">Expiring / Expired</div>
                </div>

                <div class="o_hospital_inventory_kpi_actions">
                    <button t-on-click="openAdjustStock"
                            data-hms-tooltip="Open stock adjustment">
                        <i class="fa fa-sliders"/> Adjust Stock
                    </button>
                </div>
            </div>

            <!-- Stock status chart -->
            <div class="o_hospital_chart_card"
                 t-if="!state.loading and state.stockStatusBreakdown.length">
                <div class="o_hospital_section_title">
                    <i class="fa fa-pie-chart"/> Stock Status Breakdown
                </div>
                <div class="o_hospital_chart_canvas_wrap">
                    <canvas t-ref="statusChart"/>
                </div>
            </div>

            <!-- Empty -->
            <div class="o_hospital_inventory_empty"
                 t-if="!state.loading and state.rows.length === 0">
                <i class="fa fa-check-circle"/>
                All stock levels healthy
            </div>

            <!-- Stock table -->
            <table class="o_hospital_inventory_table"
                   t-if="!state.loading and state.rows.length">
                <thead>
                    <tr>
                        <th>Medicine</th>
                        <th>On Hand</th>
                        <th>Reorder Threshold</th>
                        <th>Status</th>
                        <th>Nearest Expiry</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="state.rows" t-as="row" t-key="row.id">
                        <td>
                            <a href="#"
                               t-on-click.prevent="() => this.openMedicine(row.product_id[0])"
                               t-esc="row.product_id[1]"/>
                        </td>
                        <td t-esc="row.qty_available"/>
                        <td t-esc="row.reorder_threshold"/>
                        <td>
                            <span class="o-hms-badge red"   t-if="row.is_low_stock">
                                <i class="fa fa-arrow-down"/> Low Stock
                            </span>
                            <span class="o-hms-badge red"   t-if="row.is_expired">
                                <i class="fa fa-ban"/> Expired
                            </span>
                            <span class="o-hms-badge orange"
                                  t-if="row.is_expiring_soon and !row.is_expired">
                                <i class="fa fa-clock-o"/> Expiring Soon
                            </span>
                            <span class="o-hms-badge green"
                                  t-if="!row.is_low_stock and !row.is_expiring_soon and !row.is_expired">
                                <i class="fa fa-check"/> OK
                            </span>
                        </td>
                        <td t-esc="row.nearest_expiry_date || '&#8212;'"/>
                    </tr>
                </tbody>
            </table>

        </div>
    </t>

</templates>
