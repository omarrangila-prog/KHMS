<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hospital_queue_ticket_paperformat" model="report.paperformat">
        <field name="name">Hospital Queue Ticket</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_height">150</field>
        <field name="page_width">80</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">3</field>
        <field name="margin_bottom">3</field>
        <field name="margin_left">3</field>
        <field name="margin_right">3</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="hospital_queue_ticket_report" model="ir.actions.report">
        <field name="name">Queue Ticket</field>
        <field name="model">hospital.visit</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hospital_reception.hospital_queue_ticket_template</field>
        <field name="report_file">hospital_reception.hospital_queue_ticket_template</field>
        <field name="binding_model_id" ref="hospital_base.model_hospital_visit"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="hospital_queue_ticket_paperformat"/>
        <field name="print_report_name">'Queue Ticket - %s' % (object.visit_code)</field>
    </record>

</odoo>
