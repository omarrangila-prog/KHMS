<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- 15 demo appointments (Phase 6 §2), spread across today and the
         next few days, referencing hospital_base's actual demo patient/
         doctor xml ids. Most are left in draft/confirmed so they show up
         on the Reception Dashboard's "Today's Appointments" list and
         exercise the check-in/no-show/cancel actions in demo mode. -->

    <record id="demo_appointment_01" model="hospital.appointment">
        <field name="patient_id" ref="hospital_base.demo_patient_11"/>
        <field name="doctor_id" ref="hospital_base.demo_doctor_1"/>
        <field name="department_id" ref="hospital_base.demo_department_general_medicine"/>
        <field name="scheduled_datetime" eval="(DateTime.datetime.now() + relativedelta(hours=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="state">confirmed</field>
    </record>

    <record id="demo_appointment_02" model="hospital.appointment">
