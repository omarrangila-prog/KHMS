<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hospital_patient_registration_wizard_view_form" model="ir.ui.view">
        <field name="name">hospital.patient.registration.wizard.view.form</field>
        <field name="model">hospital.patient.registration.wizard</field>
        <field name="arch" type="xml">
            <form string="Register Patient">
                <div class="alert alert-warning o_hospital_duplicate_warning" role="alert" invisible="not has_duplicate_warning">
                    <strong>Possible match found:</strong>
                    <field name="duplicate_patient_ids" widget="many2many_tags" readonly="1" nolabel="1"/>
                </div>
                <group>
                    <field name="patient_id" string="Search Existing Patient"/>
                </group>
                <group string="New Patient Details" invisible="patient_id">
                    <group>
                        <field name="name" required="not patient_id"/>
                        <field name="date_of_birth" required="not patient_id"/>
                        <field name="gender"/>
                    </group>
                    <group>
                        <field name="phone" required="not patient_id"/>
                        <field name="mobile"/>
                        <field name="email"/>
                        <field name="identity_type"/>
                        <field name="identity_number"/>
                    </group>
                    <group string="Emergency Contact">
                        <field name="emergency_contact_name"/>
                        <field name="emergency_contact_phone"/>
                    </group>
                </group>
                <group string="Assign &amp; Queue">
                    <group>
                        <field name="doctor_id"/>
                        <field name="department_id"/>
                    </group>
                    <group>
                        <field name="payer_type" widget="radio"/>
                        <field name="priority"/>
                    </group>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Register &amp; Queue" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="hospital_patient_registration_wizard_action" model="ir.actions.act_window">
        <field name="name">Register Patient</field>
        <field name="res_model">hospital.patient.registration.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
