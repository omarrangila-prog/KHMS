<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hospital_appointment_view_form" model="ir.ui.view">
        <field name="name">hospital.appointment.view.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form string="Appointment">
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_check_in" type="object" string="Check In" class="oe_highlight" invisible="state not in ('draft', 'confirmed')"/>
                    <button name="action_no_show" type="object" string="Mark No-Show" invisible="state not in ('draft', 'confirmed')"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('checked_in', 'cancelled', 'no_show')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,checked_in"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Patient">
                            <field name="patient_id"/>
                            <field name="scheduled_datetime"/>
                        </group>
                        <group string="Assignment">
                            <field name="doctor_id"/>
                            <field name="department_id"/>
                        </group>
                    </group>
                    <group string="Visit" invisible="not visit_id">
                        <field name="visit_id" readonly="1"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hospital_appointment_view_list" model="ir.ui.view">
        <field name="name">hospital.appointment.view.list</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <list string="Appointments">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="scheduled_datetime"/>
                <field name="doctor_id"/>
                <field name="department_id"/>
                <field name="state" widget="badge" decoration-success="state == 'checked_in'" decoration-danger="state in ('cancelled', 'no_show')"/>
            </list>
        </field>
    </record>

    <record id="hospital_appointment_view_calendar" model="ir.ui.view">
        <field name="name">hospital.appointment.view.calendar</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <calendar string="Appointments" date_start="scheduled_datetime" color="doctor_id" mode="week" event_limit="5">
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="hospital_appointment_view_search" model="ir.ui.view">
        <field name="name">hospital.appointment.view.search</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <search string="Search Appointments">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="department_id"/>
                <filter string="Today" name="filter_today" domain="[('scheduled_datetime', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0))), ('scheduled_datetime', '&lt;=', datetime.datetime.combine(context_today(), datetime.time(23,59,59)))]"/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="filter_confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="Checked In" name="filter_checked_in" domain="[('state', '=', 'checked_in')]"/>
                <separator/>
                <filter string="No Show" name="filter_no_show" domain="[('state', '=', 'no_show')]"/>
                <filter string="Cancelled" name="filter_cancelled" domain="[('state', '=', 'cancelled')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="groupby_state" context="{'group_by': 'state'}"/>
                    <filter string="Doctor" name="groupby_doctor" context="{'group_by': 'doctor_id'}"/>
                    <filter string="Department" name="groupby_department" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hospital_appointment_action" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="search_view_id" ref="hospital_appointment_view_search"/>
        <field name="context">{'search_default_filter_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Book the first appointment
            </p>
        </field>
    </record>

</odoo>
