<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="hospital_reception.ReceptionDashboard">
        <div class="o_hospital_reception_dashboard">
            <div class="o_hospital_dashboard_header">
                <h2>Reception Dashboard</h2>
                <div class="o_hospital_dashboard_actions">
                    <button class="btn btn-secondary" t-on-click="openSearchPatients">
                        <i class="fa fa-search"/> Search
                    </button>
                    <button class="btn btn-primary" t-on-click="openNewRegistration">
                        <i class="fa fa-plus"/> New Registration
                    </button>
                </div>
            </div>

            <div class="o_hospital_dashboard_error alert alert-danger" t-if="state.error" role="alert">
                Couldn't load the dashboard.
                <button class="btn btn-link" t-on-click="onRetry">Retry</button>
            </div>

            <div class="o_hospital_kpi_strip">
                <t t-if="state.loading">
                    <div class="o_hospital_kpi_card o_hospital_skeleton" t-foreach="[1,2,3]" t-as="i" t-key="i"/>
                </t>
                <t t-else="">
                    <div class="o_hospital_kpi_card">
                        <span class="o_hospital_kpi_value" t-esc="state.kpi.waiting"/>
                        <span class="o_hospital_kpi_label">Waiting</span>
                    </div>
                    <div class="o_hospital_kpi_card">
                        <span class="o_hospital_kpi_value" t-esc="state.kpi.in_consult"/>
                        <span class="o_hospital_kpi_label">In Consult</span>
                    </div>
                    <div class="o_hospital_kpi_card">
                        <span class="o_hospital_kpi_value" t-esc="state.kpi.completed_today"/>
                        <span class="o_hospital_kpi_label">Completed Today</span>
                    </div>
                </t>
            </div>

            <div class="o_hospital_dashboard_columns">
                <div class="o_hospital_queue_column">
                    <h3>Live Queue</h3>
                    <div class="o_hospital_queue_empty" t-if="!state.loading and state.queueByDoctor.length === 0">
                        No patients waiting -- queue is clear.
                    </div>
                    <div class="o_hospital_queue_kanban">
                        <t t-if="state.loading">
                            <div class="o_hospital_queue_doctor_card o_hospital_skeleton" t-foreach="[1,2,3]" t-as="i" t-key="i"/>
                        </t>
                        <t t-else="">
                            <div class="o_hospital_queue_doctor_card" t-foreach="state.queueByDoctor" t-as="group" t-key="group.doctorId or 'none'">
                                <div class="o_hospital_queue_doctor_header">
                                    <strong t-esc="group.doctorName"/>
                                    <span class="badge text-bg-primary" t-esc="group.count"/>
                                </div>
                                <div class="o_hospital_queue_visit_row"
                                     t-foreach="group.visits" t-as="visit" t-key="visit.id"
                                     t-on-click="() => this.openVisit(visit.id)">
                                    <span class="o_hospital_queue_visit_code" t-esc="visit.visit_code"/>
                                    <span t-esc="visit.patient_id[1]"/>
                                    <span class="badge text-bg-danger" t-if="visit.priority === 'emergency'">Emergency</span>
                                    <span class="badge text-bg-warning" t-if="visit.priority === 'urgent'">Urgent</span>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>

                <div class="o_hospital_appointments_column">
                    <h3>Today's Appointments</h3>
                    <div class="o_hospital_appointments_empty" t-if="!state.loading and state.appointments.length === 0">
                        No appointments scheduled for today.
                    </div>
                    <table class="o_hospital_appointments_list" t-if="!state.loading and state.appointments.length">
                        <tbody>
                            <tr t-foreach="state.appointments" t-as="appt" t-key="appt.id">
                                <td class="o_hospital_appt_time" t-esc="appt.scheduled_datetime"/>
                                <td t-esc="appt.patient_id[1]" t-on-click="() => this.openAppointment(appt.id)"/>
                                <td t-esc="appt.doctor_id ? appt.doctor_id[1] : '-'"/>
                                <td>
                                    <span class="badge text-bg-secondary" t-esc="appt.state"/>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary"
                                            t-if="appt.state === 'draft' or appt.state === 'confirmed'"
                                            t-on-click="() => this.checkInAppointment(appt.id)">
                                        Check In
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <div t-if="state.loading" class="o_hospital_skeleton o_hospital_appointments_skeleton"/>
                </div>
            </div>
        </div>
    </t>

</templates>
