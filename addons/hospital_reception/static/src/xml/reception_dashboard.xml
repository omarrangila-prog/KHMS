<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="hospital_reception.ReceptionDashboard">
        <div class="o_hospital_reception_dashboard">

            <!-- Header -->
            <div class="o_hospital_dashboard_header">
                <div class="o_hospital_header_left">
                    <div class="o_hospital_header_icon">
                        <i class="fa fa-hospital-o"/>
                    </div>
                    <h2>
                        Reception
                        <small>Front-desk operations</small>
                    </h2>
                </div>
                <div class="o_hospital_dashboard_actions">
                    <button class="btn btn-secondary" t-on-click="openSearchPatients">
                        <i class="fa fa-search"/> Search Patient
                    </button>
                    <button class="btn btn-primary" t-on-click="openNewRegistration">
                        <i class="fa fa-plus"/> New Registration
                    </button>
                </div>
            </div>

            <!-- Error -->
            <div class="alert-danger" t-if="state.error">
                <i class="fa fa-exclamation-triangle"/>
                Could not load dashboard.
                <button class="btn btn-link p-0 ms-2" t-on-click="onRetry">Retry</button>
            </div>

            <!-- KPI Strip -->
            <div class="o_hospital_kpi_strip">
                <t t-if="state.loading">
                    <div class="o_hospital_kpi_card o_hospital_skeleton"
                         t-foreach="[1,2,3]" t-as="i" t-key="i"
                         style="min-height:110px"/>
                </t>
                <t t-else="">
                    <div class="o_hospital_kpi_card">
                        <div class="o_hospital_kpi_row">
                            <div>
                                <div class="o_hospital_kpi_value" t-esc="state.kpi.waiting"/>
                                <div class="o_hospital_kpi_label">Waiting</div>
                            </div>
                            <div class="o_hospital_kpi_icon">
                                <i class="fa fa-clock-o"/>
                            </div>
                        </div>
                    </div>
                    <div class="o_hospital_kpi_card">
                        <div class="o_hospital_kpi_row">
                            <div>
                                <div class="o_hospital_kpi_value" t-esc="state.kpi.in_consult"/>
                                <div class="o_hospital_kpi_label">In Consult</div>
                            </div>
                            <div class="o_hospital_kpi_icon">
                                <i class="fa fa-stethoscope"/>
                            </div>
                        </div>
                    </div>
                    <div class="o_hospital_kpi_card">
                        <div class="o_hospital_kpi_row">
                            <div>
                                <div class="o_hospital_kpi_value" t-esc="state.kpi.completed_today"/>
                                <div class="o_hospital_kpi_label">Completed Today</div>
                            </div>
                            <div class="o_hospital_kpi_icon">
                                <i class="fa fa-check-circle"/>
                            </div>
                        </div>
                    </div>
                </t>
            </div>

            <!-- Body -->
            <div class="o_hospital_dashboard_columns">

                <!-- Live Queue -->
                <div class="o_hospital_queue_column">
                    <div class="o_hospital_section_title">
                        <i class="fa fa-list-ul"/> Live Queue
                    </div>
                    <div class="o_hospital_skeleton" style="height:180px" t-if="state.loading"/>
                    <div class="o_hospital_queue_empty" t-elif="state.queueByDoctor.length === 0">
                        <i class="fa fa-check-circle"/>
                        Queue is clear
                    </div>
                    <div class="o_hospital_queue_kanban" t-else="">
                        <div class="o_hospital_queue_doctor_card"
                             t-foreach="state.queueByDoctor" t-as="group"
                             t-key="group.doctorId or 'none'">
                            <div class="o_hospital_queue_doctor_header">
                                <div class="o_hospital_doctor_name_row">
                                    <div class="o_hospital_doctor_avatar">
                                        <i class="fa fa-user-md"/>
                                    </div>
                                    <strong t-esc="group.doctorName"/>
                                </div>
                                <span class="badge" t-esc="group.count"/>
                            </div>
                            <div t-foreach="group.visits" t-as="visit" t-key="visit.id"
                                 class="o_hospital_queue_visit_row"
                                 t-on-click="() => this.openVisit(visit.id)">
                                <span class="o_hospital_queue_visit_code" t-esc="visit.visit_code"/>
                                <span class="o_hospital_visit_patient" t-esc="visit.patient_id[1]"/>
                                <span class="o-hms-badge red"
                                      t-if="visit.priority === 'emergency'">
                                    <i class="fa fa-bolt"/> Emergency
                                </span>
                                <span class="o-hms-badge orange"
                                      t-if="visit.priority === 'urgent'">
                                    <i class="fa fa-arrow-up"/> Urgent
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Appointments -->
                <div class="o_hospital_appointments_column">
                    <div class="o_hospital_appt_header">
                        <div class="o_hospital_section_title" style="margin:0">
                            <i class="fa fa-calendar"/> Today&#39;s Appointments
                        </div>
                    </div>
                    <div class="o_hospital_appointments_empty"
                         t-if="!state.loading and state.appointments.length === 0">
                        <i class="fa fa-calendar-o"/>
                        No appointments today
                    </div>
                    <table class="o_hospital_appointments_list"
                           t-if="!state.loading and state.appointments.length">
                        <tbody>
                            <tr t-foreach="state.appointments" t-as="appt" t-key="appt.id">
                                <td style="font-family:var(--o-hospital-font-mono,'SF Mono',monospace);font-size:11px;color:#636366;white-space:nowrap"
                                    t-esc="appt.scheduled_datetime"/>
                                <td style="font-weight:600;cursor:pointer"
                                    t-esc="appt.patient_id[1]"
                                    t-on-click="() => this.openAppointment(appt.id)"/>
                                <td style="color:#636366;font-size:12px"
                                    t-esc="appt.doctor_id ? appt.doctor_id[1] : '&#8212;'"/>
                                <td>
                                    <span class="o-hms-badge blue" t-esc="appt.state"/>
                                </td>
                                <td>
                                    <button class="btn-outline-primary"
                                            t-if="appt.state === 'draft' or appt.state === 'confirmed'"
                                            t-on-click="() => this.checkInAppointment(appt.id)">
                                        <i class="fa fa-sign-in"/> Check In
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <div t-if="state.loading" class="o_hospital_skeleton"
                         style="height:160px;margin:12px"/>
                </div>

            </div>
        </div>
    </t>

</templates>
