<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="seq_hospital_appointment" model="ir.sequence">
        <field name="name">Hospital Appointment</field>
        <field name="code">hospital.appointment</field>
        <field name="prefix">APT/</field>
        <field name="padding">5</field>
        <field name="number_increment">1</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_hospital_queue_ticket" model="ir.sequence">
        <field name="name">Hospital Queue Ticket</field>
        <field name="code">hospital.queue.ticket</field>
        <field name="prefix">TKT/</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
