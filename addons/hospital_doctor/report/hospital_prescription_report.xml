<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hospital_prescription_report" model="ir.actions.report">
        <field name="name">Prescription</field>
        <field name="model">hospital.prescription</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hospital_doctor.hospital_prescription_template</field>
        <field name="report_file">hospital_doctor.hospital_prescription_template</field>
        <field name="binding_model_id" ref="model_hospital_prescription"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Prescription - %s' % (object.patient_id.name)</field>
    </record>

</odoo>
