<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <record id="group_hospital_radiology_tech" model="res.groups">
        <field name="name">Hospital Radiology Technician</field>
        <field name="privilege_id" ref="hospital_base.hospital_groups_privilege"/>
        <field name="implied_ids" eval="[(4, ref('hospital_base.group_hospital_user'))]"/>
        <field name="comment">Radiology staff: schedule imaging, perform studies, enter findings and attach images.</field>
    </record>

    <!-- Multi-company record rule on hospital.radiology.order (company_id
         is a stored related from visit_id.company_id). -->
    <record id="hospital_radiology_order_company_rule" model="ir.rule">
        <field name="name">Radiology Order: multi-company isolation</field>
        <field name="model_id" ref="model_hospital_radiology_order"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hospital_base.group_hospital_user'))]"/>
    </record>

</odoo>
