<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Radiology Order: List view (the Radiology Dashboard queue) -->
    <record id="hospital_radiology_order_view_list" model="ir.ui.view">
        <field name="name">hospital.radiology.order.list</field>
        <field name="model">hospital.radiology.order</field>
        <field name="arch" type="xml">
            <list string="Radiology Orders"
                  default_order="priority desc, create_date asc"
                  decoration-danger="state == 'cancelled'"
                  decoration-success="state == 'completed'"
                  decoration-warning="priority in ('urgent', 'emergency')">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="study_id"/>
                <field name="doctor_id"/>
                <field name="priority"
                       widget="badge"
                       decoration-danger="priority == 'emergency'"
                       decoration-warning="priority == 'urgent'"
                       decoration-info="priority == 'normal'"/>
                <field name="scheduled_datetime"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state == 'completed'"
                       decoration-danger="state == 'cancelled'"
                       decoration-warning="state == 'in_progress'"
                       decoration-info="state in ('ordered', 'scheduled')"/>
                <field name="company_id" column_invisible="True"/>
                <button name="action_schedule" type="object"
                        string="Schedule"
                        icon="fa-calendar"
                        invisible="state != 'ordered'"/>
                <button name="action_start" type="object"
                        string="Start"
                        icon="fa-play"
                        invisible="state != 'scheduled'"/>
                <button name="action_complete" type="object"
                        string="Complete"
                        icon="fa-check"
                        invisible="state != 'in_progress'"/>
            </list>
        </field>
    </record>

    <!-- Radiology Order: Form view -->
    <record id="hospital_radiology_order_view_form" model="ir.ui.view">
        <field name="name">hospital.radiology.order.form</field>
        <field name="model">hospital.radiology.order</field>
        <field name="arch" type="xml">
            <form string="Radiology Order">
                <header>
                    <button name="action_schedule" type="object"
                            string="Schedule"
                            class="btn-primary"
                            invisible="state != 'ordered'"/>
                    <button name="action_start" type="object"
                            string="Start Study"
                            class="btn-primary"
                            invisible="state != 'scheduled'"/>
                    <button name="action_complete" type="object"
                            string="Mark Completed"
                            class="btn-primary"
                            invisible="state != 'in_progress'"/>
                    <button name="action_cancel_wizard" type="object"
                            string="Cancel"
                            class="btn-secondary"
                            invisible="state in ('completed', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="ordered,scheduled,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Order Details">
                            <field name="visit_id"/>
                            <field name="patient_id" readonly="1"/>
                            <field name="doctor_id"/>
                            <field name="study_id"/>
                            <field name="priority"/>
                        </group>
                        <group string="Scheduling / Execution">
                            <field name="scheduled_datetime"/>
                            <field name="performed_by" readonly="1"/>
                            <field name="performed_at" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Cancellation" invisible="state != 'cancelled'">
                        <field name="cancel_reason" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Findings / Results" name="results">
                            <field name="result_ids">
                                <list editable="bottom">
                                    <field name="findings_text"/>
                                    <field name="impression_text"/>
                                    <field name="reported_by"/>
                                    <field name="reported_at"/>
                                    <field name="verified_by"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Radiology Order: Kanban view -->
    <record id="hospital_radiology_order_view_kanban" model="ir.ui.view">
        <field name="name">hospital.radiology.order.kanban</field>
        <field name="model">hospital.radiology.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="study_id"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="scheduled_datetime"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_top">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                            </div>
                            <field name="priority" widget="priority"/>
                        </div>
                        <div>
                            <field name="patient_id"/>
                        </div>
                        <div>
                            <field name="study_id"/>
                        </div>
                        <div>
                            <field name="state" widget="badge"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Radiology Order: Search view -->
    <record id="hospital_radiology_order_view_search" model="ir.ui.view">
        <field name="name">hospital.radiology.order.search</field>
        <field name="model">hospital.radiology.order</field>
        <field name="arch" type="xml">
            <search string="Search Radiology Orders">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="study_id"/>
                <field name="doctor_id"/>
                <filter string="Ordered" name="filter_ordered"
                        domain="[('state', '=', 'ordered')]"/>
                <filter string="Scheduled" name="filter_scheduled"
                        domain="[('state', '=', 'scheduled')]"/>
                <filter string="In Progress" name="filter_in_progress"
                        domain="[('state', '=', 'in_progress')]"/>
                <filter string="Completed" name="filter_completed"
                        domain="[('state', '=', 'completed')]"/>
                <filter string="Cancelled" name="filter_cancelled"
                        domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Urgent / Emergency" name="filter_urgent"
                        domain="[('priority', 'in', ['urgent', 'emergency'])]"/>
                <filter string="Pending" name="filter_pending"
                        domain="[('state', 'not in', ['completed', 'cancelled'])]"/>
                <group>
                    <filter string="Priority" name="group_priority"
                            context="{'group_by': 'priority'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Study / Modality" name="group_study"
                            context="{'group_by': 'study_id'}"/>
                    <filter string="Doctor" name="group_doctor"
                            context="{'group_by': 'doctor_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action: Radiology Order Queue -->
    <record id="action_hospital_radiology_order" model="ir.actions.act_window">
        <field name="name">Radiology Order Queue</field>
        <field name="res_model">hospital.radiology.order</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="hospital_radiology_order_view_search"/>
        <field name="context">{'search_default_filter_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No pending radiology orders.
            </p>
        </field>
    </record>

    <!-- Action: Cancel wizard (launched from form button) -->
    <record id="action_hospital_radiology_order_cancel_wizard" model="ir.actions.act_window">
        <field name="name">Cancel Radiology Order</field>
        <field name="res_model">hospital.radiology.order.cancel.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_hospital_radiology_order"/>
        <field name="binding_view_types">form</field>
    </record>

</odoo>
