<?xml version="1.0" encoding="utf-8"?>
<!-- Default radiology study catalog — loaded in all environments (not demo-only).
     5 standard imaging studies covering the most common modalities. -->
<odoo noupdate="1">

    <!-- 1. Chest X-Ray — most common plain film study -->
    <record id="radiology_study_cxr" model="hospital.radiology.study">
        <field name="name">Chest X-Ray (PA View)</field>
        <field name="code">CXR-PA</field>
        <field name="modality">xray</field>
        <field name="price">25.00</field>
        <field name="description">Posteroanterior chest radiograph. No special preparation required. Removes jewellery/metal from chest area. Pregnancy must be declared before exposure.</field>
    </record>

    <!-- 2. CT Head — emergency and neurological workup -->
    <record id="radiology_study_ct_head" model="hospital.radiology.study">
        <field name="name">CT Head (Non-Contrast)</field>
        <field name="code">CT-HEAD-NC</field>
        <field name="modality">ct</field>
        <field name="price">120.00</field>
        <field name="description">Non-contrast CT of the brain and skull base. No preparation required for non-contrast study. Inform radiologist of any metal implants or pacemakers.</field>
    </record>

    <!-- 3. MRI Spine — musculoskeletal and neurological -->
    <record id="radiology_study_mri_spine" model="hospital.radiology.study">
        <field name="name">MRI Spine (Lumbar)</field>
        <field name="code">MRI-LS</field>
        <field name="modality">mri</field>
        <field name="price">200.00</field>
        <field name="description">MRI of lumbar spine, sagittal and axial sequences. Contraindicated with cochlear implants, pacemakers, or certain metal implants. Remove all metal objects. Claustrophobic patients may require sedation.</field>
    </record>

    <!-- 4. Ultrasound Abdomen — soft tissue and organ assessment -->
    <record id="radiology_study_us_abdomen" model="hospital.radiology.study">
        <field name="name">Ultrasound Abdomen</field>
        <field name="code">US-ABD</field>
        <field name="modality">ultrasound</field>
        <field name="price">50.00</field>
        <field name="description">B-mode ultrasound of liver, gallbladder, pancreas, spleen, kidneys, and aorta. Patient should fast for 4–6 hours prior to examination for optimal gallbladder visualisation.</field>
    </record>

    <!-- 5. Mammography — breast cancer screening and diagnosis -->
    <record id="radiology_study_mammo" model="hospital.radiology.study">
        <field name="name">Mammography (Bilateral)</field>
        <field name="code">MAMMO-BIL</field>
        <field name="modality">mammography</field>
        <field name="price">80.00</field>
        <field name="description">Bilateral two-view mammography (CC and MLO). Avoid deodorant, powder, or lotion on day of examination. Inform radiologist of any breast implants, previous biopsies, or hormone therapy.</field>
    </record>

</odoo>
