<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!--
        Cross-module multi-company isolation rules.

        hospital_base already seeds company rules for patient/visit/dept/doctor.
        This module adds the same guard for every downstream clinical model so
        that a user belonging to Company A cannot read Company B records even if
        they navigate directly to the model.
    -->

    <!-- hospital_reception: appointment -->
    <record id="hospital_appointment_company_rule" model="ir.rule">
        <field name="name">Hospital Appointment: multi-company isolation</field>
        <field name="model_id" ref="hospital_reception.model_hospital_appointment"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hospital_base.group_hospital_user'))]"/>
    </record>

