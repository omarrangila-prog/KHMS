<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="hospital_nurse.VitalsQuickEntry">
        <div class="o_hospital_vitals_quick_entry">
            <h2>Vitals Quick-Entry</h2>

            <div class="alert alert-danger" t-if="state.error" role="alert" t-esc="state.error"/>

            <div class="o_hospital_vitals_row">
                <label>Blood Pressure (mmHg)</label>
                <div class="o_hospital_stepper_group">
                    <button class="btn btn-outline-secondary" t-on-click="() => this.step('blood_pressure_systolic', -1)">-</button>
                    <input type="number" t-att-class="isAbnormal('blood_pressure_systolic') ? 'o_hospital_input_abnormal' : ''"
                           t-att-value="state.values.blood_pressure_systolic"
                           t-on-change="(ev) => this.onFieldInput('blood_pressure_systolic', ev)"/>
                    <button class="btn btn-outline-secondary" t-on-click="() => this.step('blood_pressure_systolic', 1)">+</button>
                    <span>/</span>
                    <button class="btn btn-outline-secondary" t-on-click="() => this.step('blood_pressure_diastolic', -1)">-</button>
                    <input type="number" t-att-value="state.values.blood_pressure_diastolic"
                           t-on-change="(ev) => this.onFieldInput('blood_pressure_diastolic', ev)"/>
                    <button class="btn btn-outline-secondary" t-on-click="() => this.step('blood_pressure_diastolic', 1)">+</button>
                </div>
            </div>

            <div class="o_hospital_vitals_row">
                <label>Pulse (bpm)</label>
                <div class="o_hospital_stepper_group">
                    <button class="btn btn-outline-secondary" t-on-click="() => this.step('pulse_rate', -1)">-</button>
                    <input type="number" t-att-class="isAbnormal('pulse_rate') ? 'o_hospital_input_abnormal' : ''"
                           t-att-value="state.values.pulse_rate"
                           t-on-change="(ev) => this.onFieldInput('pulse_rate', ev)"/>
                    <button class="btn btn-outline-secondary" t-on-click="() => this.step('pulse_rate', 1)">+</button>
                </div>
            </div>

            <div class="o_hospital_vitals_row">
                <label>Temp (°C)</label>
                <div class="o_hospital_stepper_group">
                    <button class="btn btn-outline-secondary" t-on-click="() => this.step('temperature', -0.1)">-</button>
                    <input type="number" step="0.1" t-att-class="isAbnormal('temperature') ? 'o_hospital_input_abnormal' : ''"
                           t-att-value="state.values.temperature"
                           t-on-change="(ev) => this.onFieldInput('temperature', ev)"/>
                    <button class="btn btn-outline-secondary" t-on-click="() => this.step('temperature', 0.1)">+</button>
                </div>
            </div>

            <div class="o_hospital_vitals_row">
                <label>SpO2 (%)</label>
                <div class="o_hospital_stepper_group">
                    <button class="btn btn-outline-secondary" t-on-click="() => this.step('spo2', -1)">-</button>
                    <input type="number" t-att-class="isAbnormal('spo2') ? 'o_hospital_input_abnormal' : ''"
                           t-att-value="state.values.spo2"
                           t-on-change="(ev) => this.onFieldInput('spo2', ev)"/>
                    <button class="btn btn-outline-secondary" t-on-click="() => this.step('spo2', 1)">+</button>
                </div>
            </div>

            <div class="o_hospital_vitals_row">
                <label>Respiratory Rate</label>
                <div class="o_hospital_stepper_group">
                    <button class="btn btn-outline-secondary" t-on-click="() => this.step('respiratory_rate', -1)">-</button>
                    <input type="number" t-att-value="state.values.respiratory_rate"
                           t-on-change="(ev) => this.onFieldInput('respiratory_rate', ev)"/>
                    <button class="btn btn-outline-secondary" t-on-click="() => this.step('respiratory_rate', 1)">+</button>
                </div>
            </div>

            <div class="o_hospital_vitals_row">
                <label>Height (cm) / Weight (kg)</label>
                <div class="o_hospital_stepper_group">
                    <input type="number" t-att-value="state.values.height_cm"
                           t-on-change="(ev) => this.onFieldInput('height_cm', ev)"/>
                    <input type="number" t-att-value="state.values.weight_kg"
                           t-on-change="(ev) => this.onFieldInput('weight_kg', ev)"/>
                </div>
            </div>

            <div class="o_hospital_bmi_display" t-att-class="bmiStatus.cssClass">
                BMI: <t t-esc="bmi.toFixed(1)"/> (<t t-esc="bmiStatus.label"/>)
            </div>

            <div class="o_hospital_vitals_row">
                <label>Notes</label>
                <textarea t-on-change="onNotesInput" t-esc="state.values.notes"/>
            </div>

            <div class="o_hospital_vitals_actions">
                <button class="btn btn-secondary" t-on-click="onCancel" t-att-disabled="state.saving">Cancel</button>
                <button class="btn btn-primary btn-lg" t-on-click="onSaveAndSendToDoctor" t-att-disabled="state.saving">
                    Save &amp; Send to Doctor
                </button>
            </div>
        </div>
    </t>

</templates>
