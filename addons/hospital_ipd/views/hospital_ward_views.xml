<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hospital_ward_view_list" model="ir.ui.view">
        <field name="name">hospital.ward.list</field>
        <field name="model">hospital.ward</field>
        <field name="arch" type="xml">
            <list string="Wards">
                <field name="name"/>
                <field name="code"/>
                <field name="ward_type"/>
                <field name="daily_rate" widget="monetary"/>
                <field name="bed_count"/>
                <field name="occupied_bed_count"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="hospital_ward_view_form" model="ir.ui.view">
        <field name="name">hospital.ward.form</field>
        <field name="model">hospital.ward</field>
        <field name="arch" type="xml">
            <form string="Ward">
                <sheet>
                    <div class="o-hms-form-header">
                        <div class="o-hms-avatar">
                            <i class="fa fa-hospital-o"/>
                        </div>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                    </div>
                    <group>
                        <group string="Ward Details" class="o-hms-card-group">
                            <field name="code"/>
                            <field name="ward_type"/>
                            <field name="daily_rate" widget="monetary"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                        <group string="Occupancy" class="o-hms-card-group">
                            <field name="bed_count"/>
                            <field name="occupied_bed_count"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Beds" name="beds">
                            <field name="bed_ids">
                                <list editable="bottom">
                                    <field name="bed_number"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'vacant'"
                                           decoration-danger="state == 'occupied'"
                                           decoration-warning="state in ('reserved', 'cleaning')"/>
                                    <field name="current_patient_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hospital_ward_view_search" model="ir.ui.view">
        <field name="name">hospital.ward.search</field>
        <field name="model">hospital.ward</field>
        <field name="arch" type="xml">
            <search string="Search Wards">
                <field name="name"/>
                <field name="code"/>
                <filter string="General" name="filter_general" domain="[('ward_type', '=', 'general')]"/>
                <filter string="ICU" name="filter_icu" domain="[('ward_type', '=', 'icu')]"/>
                <group>
                    <filter string="Ward Type" name="group_ward_type" context="{'group_by': 'ward_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hospital_ward" model="ir.actions.act_window">
        <field name="name">Wards</field>
        <field name="res_model">hospital.ward</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hospital_ward_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first ward.
            </p>
        </field>
    </record>

</odoo>
