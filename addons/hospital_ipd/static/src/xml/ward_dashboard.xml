<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="hospital_ipd.WardDashboard">
        <div class="o_hospital_ward_dashboard">

            <!-- Header -->
            <div class="o_hospital_dashboard_header">
                <div class="o_hospital_header_left">
                    <div class="o_hospital_header_icon">
                        <i class="fa fa-bed"/>
                    </div>
                    <h2>
                        Ward Dashboard
                        <small>Bed occupancy &#183; real-time</small>
                    </h2>
                </div>
            </div>

            <!-- Error -->
            <div class="alert-danger" t-if="state.error">
                <i class="fa fa-exclamation-triangle"/>
                Could not load ward data.
                <button class="btn btn-link p-0 ms-2" t-on-click="onRetry">Retry</button>
            </div>

            <!-- Skeleton -->
            <div class="o_hospital_skeleton" t-if="state.loading"/>

            <div t-if="!state.loading and !state.error">

                <!-- Empty -->
                <div class="o_hospital_ward_empty" t-if="!state.wards.length">
                    <i class="fa fa-bed"/>
                    No wards configured yet.
                </div>

                <div t-else="">
                    <div class="o_hospital_chart_card">
                        <div class="o_hospital_section_title">
                            <i class="fa fa-bar-chart"/> Bed Status by Ward
                        </div>
                        <div class="o_hospital_chart_canvas_wrap">
                            <canvas t-ref="occupancyChart"/>
                        </div>
                    </div>

                    <div class="o_hospital_ward_section"
                         t-foreach="state.wards" t-as="ward" t-key="ward.id">
                        <div class="o_hospital_ward_section_header">
                            <div class="o_hospital_ward_title_row">
                                <h3 t-esc="ward.name"/>
                                <span class="badge" t-esc="ward.ward_type"/>
                            </div>
                            <div class="o_hospital_ward_occupancy_bar">
                                <span>
                                    <t t-esc="ward.occupied_bed_count"/>/<t t-esc="ward.bed_count"/>
                                </span>
                                <div class="o_hospital_bar_track">
                                    <div class="o_hospital_bar_fill"
                                         t-attf-style="width:{{ ward.bed_count ? Math.round(ward.occupied_bed_count / ward.bed_count * 100) : 0 }}%"/>
                                </div>
                            </div>
                        </div>

                        <div class="o_hospital_bed_grid">
                            <div t-foreach="ward.beds" t-as="bed" t-key="bed.id"
                                 t-attf-class="o_hospital_bed_tile {{ this.getBedStatusClass(bed) }}"
                                 t-on-click="() => this.onBedClick(bed)">
                                <i t-attf-class="fa {{ bed.state === 'occupied' ? 'fa-user' : bed.state === 'reserved' ? 'fa-bookmark' : bed.state === 'cleaning' ? 'fa-refresh' : 'fa-bed' }} o_hospital_bed_icon"/>
                                <div class="o_hospital_bed_number" t-esc="bed.bed_number"/>
                                <div class="o_hospital_bed_state" t-esc="bed.state"/>
                                <div class="o_hospital_bed_patient"
                                     t-if="bed.current_patient_id"
                                     t-esc="bed.current_patient_id[1]"/>
                            </div>
                        </div>
                    </div>

                    <!-- Legend -->
                    <div class="o_hospital_ward_legend">
                        <div class="o_hospital_legend_item">
                            <span class="o_hospital_legend_dot vacant"/>
                            <i class="fa fa-bed" style="font-size:11px;opacity:0.5"/> Vacant
                        </div>
                        <div class="o_hospital_legend_item">
                            <span class="o_hospital_legend_dot occupied"/>
                            <i class="fa fa-user" style="font-size:11px;opacity:0.5"/> Occupied
                        </div>
                        <div class="o_hospital_legend_item">
                            <span class="o_hospital_legend_dot reserved"/>
                            <i class="fa fa-bookmark" style="font-size:11px;opacity:0.5"/> Reserved
                        </div>
                        <div class="o_hospital_legend_item">
                            <span class="o_hospital_legend_dot cleaning"/>
                            <i class="fa fa-refresh" style="font-size:11px;opacity:0.5"/> Cleaning
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </t>

</templates>
