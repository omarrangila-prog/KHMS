<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="hospital_ipd.WardDashboard">
        <div class="o_hospital_ward_dashboard">

            <div class="o_hospital_dashboard_header">
                <h2>Ward Dashboard</h2>
                <small class="text-muted" t-if="!state.loading">
                    Click a vacant bed to admit, an occupied bed to discharge.
                </small>
            </div>

            <div class="o_hospital_dashboard_error alert alert-danger"
                 t-if="state.error" role="alert">
                Couldn't load the ward dashboard.
                <button class="btn btn-link" t-on-click="onRetry">Retry</button>
            </div>

            <div class="o_hospital_skeleton" t-if="state.loading"/>

            <div class="o_hospital_ward_grid" t-if="!state.loading and !state.error">
                <div class="o_hospital_ward_empty" t-if="!state.wards.length">
                    No wards configured.
                </div>
                <div class="o_hospital_ward_section" t-foreach="state.wards" t-as="ward" t-key="ward.id">
                    <div class="o_hospital_ward_section_header">
                        <h3>
                            <t t-esc="ward.name"/>
                            <span class="badge text-bg-secondary ms-2" t-esc="ward.ward_type"/>
                        </h3>
                        <span class="text-muted">
                            <t t-esc="ward.occupied_bed_count"/> / <t t-esc="ward.bed_count"/> occupied
                        </span>
                    </div>
                    <div class="o_hospital_bed_grid">
                        <div t-foreach="ward.beds" t-as="bed" t-key="bed.id"
                             t-attf-class="o_hospital_bed_tile {{ this.getBedStatusClass(bed) }}"
                             t-on-click="() => this.onBedClick(bed)">
                            <div class="o_hospital_bed_number" t-esc="bed.bed_number"/>
                            <div class="o_hospital_bed_state" t-esc="bed.state"/>
                            <div class="o_hospital_bed_patient"
                                 t-if="bed.current_patient_id"
                                 t-esc="bed.current_patient_id[1]"/>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
