<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="hospital_dashboard.ExecutiveDashboard">
        <div class="o_hospital_executive_dashboard">

            <div class="o_hospital_dashboard_header">
                <h2>Executive Dashboard</h2>
                <button class="btn btn-outline-secondary btn-sm" t-on-click="onRetry">Refresh</button>
            </div>

            <div class="o_hospital_dashboard_error alert alert-danger"
                 t-if="state.error" role="alert">
                Couldn't load the executive dashboard.
                <button class="btn btn-link" t-on-click="onRetry">Retry</button>
            </div>

            <div class="o_hospital_skeleton" t-if="state.loading"/>

            <div class="o_hospital_kpi_grid" t-if="!state.loading and !state.error and state.kpi">
                <div class="o_hospital_kpi_card">
                    <div class="o_hospital_kpi_label">Patients Today</div>
                    <div class="o_hospital_kpi_value" t-esc="state.kpi.patients_today"/>
                </div>
                <div class="o_hospital_kpi_card">
                    <div class="o_hospital_kpi_label">Patients This Week</div>
                    <div class="o_hospital_kpi_value" t-esc="state.kpi.patients_this_week"/>
                </div>
                <div class="o_hospital_kpi_card">
                    <div class="o_hospital_kpi_label">Bed Occupancy</div>
                    <div class="o_hospital_kpi_value" t-esc="this.formatPercent(state.kpi.bed_occupancy_pct)"/>
                </div>
                <div class="o_hospital_kpi_card">
                    <div class="o_hospital_kpi_label">Avg. Doctor Wait</div>
                    <div class="o_hospital_kpi_value" t-esc="this.formatMinutes(state.kpi.avg_wait_minutes)"/>
                </div>
                <div class="o_hospital_kpi_card o_hospital_kpi_card_wide">
                    <div class="o_hospital_kpi_label">Ward Revenue (Confirmed Discharges)</div>
                    <div class="o_hospital_kpi_value" t-esc="state.kpi.ward_revenue_total"/>
                </div>
            </div>

            <div class="o_hospital_kpi_empty" t-if="!state.loading and !state.error and !state.kpi">
                No KPI data available yet.
            </div>
        </div>
    </t>

</templates>
