<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hospital_dashboard_kpi_view_list" model="ir.ui.view">
        <field name="name">hospital.dashboard.kpi.list</field>
        <field name="model">hospital.dashboard.kpi</field>
        <field name="arch" type="xml">
            <list string="KPI Snapshot" create="0" edit="0" delete="0">
                <field name="company_id"/>
                <field name="patients_today"/>
                <field name="patients_this_week"/>
                <field name="bed_occupancy_pct" widget="percentage"/>
                <field name="avg_wait_minutes"/>
                <field name="ward_revenue_total" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="hospital_dashboard_kpi_action" model="ir.actions.act_window">
        <field name="name">KPI Snapshot (List)</field>
        <field name="res_model">hospital.dashboard.kpi</field>
        <field name="view_mode">list</field>
    </record>

    <record id="hospital_dashboard_executive_action" model="ir.actions.client">
        <field name="name">Executive Dashboard</field>
        <field name="tag">hospital_dashboard.executive_dashboard</field>
    </record>

</odoo>
