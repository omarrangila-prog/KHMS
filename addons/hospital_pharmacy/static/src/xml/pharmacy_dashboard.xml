<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="hospital_pharmacy.PharmacyDashboard">
        <div class="o_hospital_pharmacy_dashboard">

            <div class="o_hospital_dashboard_header">
                <h2>Pharmacy</h2>
                <div class="o_hospital_pharmacy_header_meta" t-if="!state.loading">
                    <span class="badge text-bg-primary">
                        <t t-esc="state.queue.length"/> pending prescriptions
                    </span>
                    <small class="text-muted ms-2">
                        Shortcuts: <kbd>D</kbd> Dispense &#160; <kbd>A</kbd> Dispense All
                    </small>
                </div>
            </div>

            <div class="o_hospital_dashboard_error alert alert-danger"
                 t-if="state.error" role="alert">
                Couldn't load the pharmacy dashboard.
                <button class="btn btn-link" t-on-click="onRetry">Retry</button>
            </div>

            <div class="o_hospital_pharmacy_split_view">

                <!-- LEFT PANE: Dispensing queue -->
                <div class="o_hospital_pharmacy_pane_queue">
                    <div class="o_hospital_doctor_pane_header">
                        <h3>Dispensing Queue</h3>
                    </div>
                    <div class="o_hospital_skeleton" t-if="state.loading"/>
                    <div class="o_hospital_pharmacy_queue_empty"
                         t-if="!state.loading and !state.queue.length">
                        No pending prescriptions.
                    </div>
                    <div class="o_hospital_pharmacy_queue_list" t-if="!state.loading">
                        <div t-foreach="state.queue" t-as="prescription" t-key="prescription.id"
                             t-attf-class="o_hospital_pharmacy_queue_row {{ state.selectedPrescriptionId === prescription.id ? 'o_hospital_pharmacy_queue_row_selected' : '' }}"
                             t-on-click="() => this.selectPrescription(prescription.id)">
                            <div class="o_hospital_pharmacy_queue_row_main">
                                <span class="o_hospital_pharmacy_queue_patient"
                                      t-esc="prescription.patient_id[1]"/>
                            </div>
                            <div class="o_hospital_pharmacy_queue_row_meta">
                                <span class="text-muted" t-esc="prescription.doctor_id[1]"/>
                                <span t-if="prescription.state === 'partially_dispensed'"
                                      class="badge text-bg-warning ms-2">Partial</span>
                                <span t-if="prescription.state === 'draft'"
                                      class="badge text-bg-secondary ms-2">Pending</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RIGHT PANE: Dispense detail for selected prescription -->
                <div class="o_hospital_pharmacy_pane_detail">
                    <div class="o_hospital_doctor_pane_header">
                        <h3>Dispense Detail</h3>
                        <div class="o_hospital_pharmacy_detail_actions"
                             t-if="state.selectedPrescriptionId">
                            <button class="btn btn-primary btn-sm"
                                    t-on-click="() => this.openDispenseWizard(state.selectedPrescriptionId)">
                                Dispense (<kbd>D</kbd>)
                            </button>
                            <button class="btn btn-outline-primary btn-sm ms-1"
                                    t-on-click="() => this.openDispenseAllWizard(state.selectedPrescriptionId)">
                                Dispense All (<kbd>A</kbd>)
                            </button>
                        </div>
                    </div>

                    <div class="o_hospital_pharmacy_detail_empty"
                         t-if="!state.selectedPrescriptionId">
                        Select a prescription from the queue to see its lines here.
                    </div>

                    <div class="o_hospital_pharmacy_lines" t-if="state.selectedPrescriptionId">
                        <div class="o_hospital_skeleton" t-if="state.loading"/>
                        <div t-if="!state.loading and !state.selectedLines.length"
                             class="text-muted p-3">
                            No pending lines for this prescription.
                        </div>
                        <table class="table table-sm table-hover o_hospital_pharmacy_lines_table"
                               t-if="!state.loading and state.selectedLines.length">
                            <thead>
                                <tr>
                                    <th>Medicine</th>
                                    <th>Prescribed</th>
                                    <th>Dispensed</th>
                                    <th>Stock</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="state.selectedLines" t-as="line" t-key="line.id">
                                    <td>
                                        <span t-esc="line.medicine_id[1]"/>
                                        <span t-if="line.has_allergy_conflict"
                                              class="badge text-bg-danger ms-1"
                                              title="Allergy conflict detected">&#x26A0; Allergy</span>
                                    </td>
                                    <td><t t-esc="line.qty_prescribed"/></td>
                                    <td><t t-esc="line.qty_dispensed"/></td>
                                    <td>
                                        <span t-att-class="this.getStockBadgeClass(line)"
                                              t-esc="line.qty_on_hand_at_pharmacy"/>
                                    </td>
                                    <td>
                                        <span class="badge"
                                              t-att-class="line.state === 'pending' ? 'text-bg-secondary' : line.state === 'partial' ? 'text-bg-warning' : line.state === 'backordered' ? 'text-bg-danger' : 'text-bg-success'"
                                              t-esc="line.state"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </t>

</templates>
