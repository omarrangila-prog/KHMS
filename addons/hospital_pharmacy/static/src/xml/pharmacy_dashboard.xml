<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="hospital_pharmacy.PharmacyDashboard">
        <div class="o_hospital_pharmacy_dashboard">

            <!-- Header -->
            <div class="o_hospital_dashboard_header">
                <div class="o_hospital_header_left">
                    <div class="o_hospital_header_icon">
                        <i class="fa fa-medkit"/>
                    </div>
                    <h2>
                        Pharmacy
                        <small>Dispensing queue</small>
                    </h2>
                </div>
                <div class="o_hospital_pharmacy_header_meta" t-if="!state.loading">
                    <span class="o-hms-badge green">
                        <i class="fa fa-list"/> <t t-esc="state.queue.length"/> pending
                    </span>
                    <small style="color:#AEAEB2">
                        <kbd>D</kbd> Dispense&#160;&#160;<kbd>A</kbd> All
                    </small>
                </div>
            </div>

            <!-- Error -->
            <div class="o_hospital_dashboard_error alert alert-danger"
                 t-if="state.error" role="alert"
                 style="display:flex;align-items:center;gap:8px;border-radius:10px;margin-bottom:16px">
                <i class="fa fa-exclamation-triangle"/>
                Couldn&#39;t load the pharmacy dashboard.
                <button class="btn btn-link p-0 ms-2" t-on-click="onRetry">Retry</button>
            </div>

            <div class="o_hospital_pharmacy_split_view">

                <!-- LEFT: Dispensing queue -->
                <div class="o_hospital_pharmacy_pane_queue">
                    <div class="o_hospital_chart_card"
                         t-if="!state.loading and state.lineStatusBreakdown.length">
                        <div class="o_hospital_section_title">
                            <i class="fa fa-pie-chart"/> Today's Dispensing Status
                        </div>
                        <div class="o_hospital_chart_canvas_wrap">
                            <canvas t-ref="statusChart"/>
                        </div>
                    </div>

                    <div class="o_hospital_pharmacy_pane_header">
                        <div class="o_hospital_section_title">
                            <i class="fa fa-list-ul"/> Dispensing Queue
                        </div>
                    </div>

                    <div class="o_hospital_skeleton" t-if="state.loading"/>

                    <div class="o_hospital_pharmacy_detail_empty"
                         t-if="!state.loading and !state.queue.length">
                        <i class="fa fa-check-circle"/>
                        No pending prescriptions
                    </div>

                    <div class="o_hospital_pharmacy_queue_list" t-if="!state.loading and state.queue.length">
                        <div t-foreach="state.queue" t-as="prescription" t-key="prescription.id"
                             t-attf-class="o_hospital_pharmacy_queue_row {{ state.selectedPrescriptionId === prescription.id ? 'o_hospital_pharmacy_queue_row_selected' : '' }}"
                             t-on-click="() => this.selectPrescription(prescription.id)">
                            <div class="o_hospital_pharmacy_queue_row_main">
                                <div class="o_hospital_queue_avatar">
                                    <i class="fa fa-user"/>
                                </div>
                                <span class="o_hospital_pharmacy_queue_patient"
                                      t-esc="prescription.patient_id[1]"/>
                            </div>
                            <div class="o_hospital_pharmacy_queue_row_meta">
                                <i class="fa fa-user-md" style="font-size:10px"/>
                                <span t-esc="prescription.doctor_id[1]"/>
                                <span class="o-hms-badge orange"
                                      t-if="prescription.state === 'partially_dispensed'">
                                    Partial
                                </span>
                                <span class="o-hms-badge grey"
                                      t-if="prescription.state === 'draft'">
                                    Pending
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RIGHT: Dispense detail -->
                <div class="o_hospital_pharmacy_pane_detail">
                    <div class="o_hospital_pharmacy_pane_header">
                        <div class="o_hospital_section_title">
                            <i class="fa fa-file-text-o"/> Dispense Detail
                        </div>
                        <div class="o_hospital_pharmacy_detail_actions"
                             t-if="state.selectedPrescriptionId">
                            <button class="btn-primary"
                                    t-on-click="() => this.openDispenseWizard(state.selectedPrescriptionId)">
                                <i class="fa fa-check"/> Dispense <kbd style="opacity:0.7;font-size:10px">D</kbd>
                            </button>
                            <button class="btn-outline-primary"
                                    t-on-click="() => this.openDispenseAllWizard(state.selectedPrescriptionId)">
                                <i class="fa fa-check-square-o"/> All <kbd style="opacity:0.7;font-size:10px">A</kbd>
                            </button>
                        </div>
                    </div>

                    <div class="o_hospital_pharmacy_detail_empty"
                         t-if="!state.selectedPrescriptionId">
                        <i class="fa fa-hand-o-left"/>
                        Select a prescription from the queue
                    </div>

                    <div class="o_hospital_pharmacy_lines" t-if="state.selectedPrescriptionId">
                        <div class="o_hospital_skeleton" t-if="state.loading"/>
                        <div t-if="!state.loading and !state.selectedLines.length"
                             style="color:#AEAEB2;padding:24px;text-align:center;font-size:13px">
                            No pending lines.
                        </div>
                        <table class="o_hospital_pharmacy_lines_table"
                               t-if="!state.loading and state.selectedLines.length">
                            <thead>
                                <tr>
                                    <th>Medicine</th>
                                    <th>Prescribed</th>
                                    <th>Dispensed</th>
                                    <th>Stock</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="state.selectedLines" t-as="line" t-key="line.id">
                                    <td>
                                        <span t-esc="line.medicine_id[1]"/>
                                        <span class="o-hms-badge red ms-1"
                                              t-if="line.has_allergy_conflict"
                                              title="Allergy conflict">
                                            <i class="fa fa-warning"/> Allergy
                                        </span>
                                    </td>
                                    <td><t t-esc="line.qty_prescribed"/></td>
                                    <td><t t-esc="line.qty_dispensed"/></td>
                                    <td>
                                        <span t-att-class="this.getStockBadgeClass(line)"
                                              t-esc="line.qty_on_hand_at_pharmacy"/>
                                    </td>
                                    <td>
                                        <span class="badge"
                                              t-att-class="line.state === 'pending' ? 'o-hms-badge grey' : line.state === 'partial' ? 'o-hms-badge orange' : line.state === 'backordered' ? 'o-hms-badge red' : 'o-hms-badge green'"
                                              t-esc="line.state"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </t>

</templates>
