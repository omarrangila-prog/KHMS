<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="seq_hospital_patient" model="ir.sequence">
        <field name="name">Hospital Patient</field>
        <field name="code">hospital.patient</field>
        <field name="prefix">PT/</field>
        <field name="padding">5</field>
        <field name="number_increment">1</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_hospital_visit" model="ir.sequence">
        <field name="name">Hospital Visit</field>
        <field name="code">hospital.visit</field>
        <field name="prefix">VS/</field>
        <field name="padding">5</field>
        <field name="number_increment">1</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
