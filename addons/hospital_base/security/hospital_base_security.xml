<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <record id="module_hospital_category" model="ir.module.category">
        <field name="name">Hospital</field>
        <field name="description">Hospital Management System</field>
        <field name="sequence">20</field>
    </record>

    <record id="hospital_groups_privilege" model="res.groups.privilege">
        <field name="name">Hospital</field>
        <field name="category_id" ref="module_hospital_category"/>
    </record>

    <record id="group_hospital_user" model="res.groups">
        <field name="name">Hospital User</field>
        <field name="privilege_id" ref="hospital_groups_privilege"/>
        <field name="comment">Base hospital access: read-only on patients and visits.</field>
    </record>

    <record id="group_hospital_admin" model="res.groups">
        <field name="name">Hospital Administrator</field>
        <field name="privilege_id" ref="hospital_groups_privilege"/>
        <field name="implied_ids" eval="[(4, ref('group_hospital_user'))]"/>
        <field name="comment">Full access to all hospital_base data, including configuration and the read-only audit log.</field>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <!-- Multi-company record rules (Phase 9 §3) -->
    <record id="hospital_patient_company_rule" model="ir.rule">
        <field name="name">Hospital Patient: multi-company isolation</field>
        <field name="model_id" ref="model_hospital_patient"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_hospital_user'))]"/>
    </record>

    <record id="hospital_visit_company_rule" model="ir.rule">
        <field name="name">Hospital Visit: multi-company isolation</field>
        <field name="model_id" ref="model_hospital_visit"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_hospital_user'))]"/>
    </record>

    <record id="hospital_department_company_rule" model="ir.rule">
        <field name="name">Hospital Department: multi-company isolation</field>
        <field name="model_id" ref="model_hospital_department"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_hospital_user'))]"/>
    </record>

    <record id="hospital_doctor_company_rule" model="ir.rule">
        <field name="name">Hospital Doctor: multi-company isolation</field>
        <field name="model_id" ref="model_hospital_doctor"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_hospital_user'))]"/>
    </record>

</odoo>
