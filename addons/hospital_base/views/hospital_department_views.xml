<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hospital_department_view_form" model="ir.ui.view">
        <field name="name">hospital.department.view.form</field>
        <field name="model">hospital.department</field>
        <field name="arch" type="xml">
            <form string="Department">
                <sheet>
                    <div class="o-hms-form-header">
                        <div class="o-hms-avatar">
                            <i class="fa fa-building"/>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Department Name"/>
                            </h1>
                        </div>
                    </div>
                    <group class="o-hms-card-group">
                        <field name="code"/>
                        <field name="active"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <notebook>
                        <page string="Doctors" name="doctors">
                            <field name="doctor_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="specialization"/>
                                    <field name="license_number"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hospital_department_view_list" model="ir.ui.view">
        <field name="name">hospital.department.view.list</field>
        <field name="model">hospital.department</field>
        <field name="arch" type="xml">
            <list string="Departments">
                <field name="code"/>
                <field name="name"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="hospital_department_view_search" model="ir.ui.view">
        <field name="name">hospital.department.view.search</field>
        <field name="model">hospital.department</field>
        <field name="arch" type="xml">
            <search string="Search Departments">
                <field name="name"/>
                <field name="code"/>
                <filter string="Archived" name="filter_inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="hospital_department_action" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">hospital.department</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hospital_department_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first hospital department
            </p>
        </field>
    </record>

</odoo>
