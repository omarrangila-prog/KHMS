<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hospital_doctor_view_form" model="ir.ui.view">
        <field name="name">hospital.doctor.view.form</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <form string="Doctor">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Identity">
                            <field name="user_id"/>
                            <field name="department_id"/>
                            <field name="active"/>
                        </group>
                        <group string="Professional Info">
                            <field name="specialization"/>
                            <field name="license_number"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Weekly Schedule" name="schedule">
                            <field name="schedule_ids">
                                <list editable="bottom">
                                    <field name="weekday"/>
                                    <field name="start_time" widget="float_time"/>
                                    <field name="end_time" widget="float_time"/>
                                    <field name="max_patients"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hospital_doctor_view_list" model="ir.ui.view">
        <field name="name">hospital.doctor.view.list</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <list string="Doctors">
                <field name="name"/>
                <field name="department_id"/>
                <field name="specialization"/>
                <field name="license_number"/>
            </list>
        </field>
    </record>

    <record id="hospital_doctor_view_search" model="ir.ui.view">
        <field name="name">hospital.doctor.view.search</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <search string="Search Doctors">
                <field name="name"/>
                <field name="specialization"/>
                <field name="department_id"/>
                <group>
                    <filter string="Department" name="groupby_department" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hospital_doctor_action" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hospital.doctor</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hospital_doctor_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first doctor
            </p>
        </field>
    </record>

</odoo>
