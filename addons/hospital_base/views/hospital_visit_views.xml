<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hospital_visit_view_form" model="ir.ui.view">
        <field name="name">hospital.visit.view.form</field>
        <field name="model">hospital.visit</field>
        <field name="arch" type="xml">
            <form string="Visit">
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_send_to_doctor" type="object" string="Send to Doctor" class="oe_highlight" invisible="state not in ('waiting_nurse', 'in_progress_multi')"/>
                    <button name="action_admit" type="object" string="Admit" invisible="visit_type != 'ipd' or state == 'admitted'"/>
                    <button name="action_to_billing" type="object" string="Move to Billing" invisible="state in ('cancelled', 'void', 'billing', 'done')"/>
                    <button name="action_done" type="object" string="Mark Done" invisible="state in ('cancelled', 'void', 'done')"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('cancelled', 'void', 'done')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,waiting_nurse,waiting_doctor,in_progress_multi,admitted,billing,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="visit_code" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Patient">
                            <field name="patient_id"/>
                            <field name="visit_type"/>
                            <field name="checkin_datetime"/>
                        </group>
                        <group string="Assignment">
                            <field name="doctor_id"/>
                            <field name="department_id"/>
                            <field name="priority"/>
                            <field name="payer_type"/>
                        </group>
                    </group>
                    <group string="Cancellation" invisible="state != 'cancelled'">
                        <field name="cancel_reason"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="hospital_visit_view_list" model="ir.ui.view">
        <field name="name">hospital.visit.view.list</field>
        <field name="model">hospital.visit</field>
        <field name="arch" type="xml">
            <list string="Visits">
                <field name="visit_code"/>
                <field name="patient_id"/>
                <field name="visit_type"/>
                <field name="doctor_id"/>
                <field name="department_id"/>
                <field name="priority" widget="badge" decoration-danger="priority == 'emergency'" decoration-warning="priority == 'urgent'"/>
                <field name="state" widget="badge"/>
                <field name="checkin_datetime"/>
            </list>
        </field>
    </record>

    <record id="hospital_visit_view_kanban" model="ir.ui.view">
        <field name="name">hospital.visit.view.kanban</field>
        <field name="model">hospital.visit</field>
        <field name="arch" type="xml">
            <kanban class="o_hospital_visit_kanban" default_group_by="state">
                <field name="visit_code"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="checkin_datetime"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <strong><field name="visit_code"/></strong>
                            <div><field name="patient_id"/></div>
                            <div><field name="doctor_id"/></div>
                            <div>
                                <span class="badge text-bg-danger" t-if="record.priority.raw_value == 'emergency'">Emergency</span>
                                <span class="badge text-bg-warning" t-if="record.priority.raw_value == 'urgent'">Urgent</span>
                            </div>
                            <div><field name="checkin_datetime"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="hospital_visit_view_search" model="ir.ui.view">
        <field name="name">hospital.visit.view.search</field>
        <field name="model">hospital.visit</field>
        <field name="arch" type="xml">
            <search string="Search Visits">
                <field name="visit_code"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="department_id"/>
                <filter string="Today" name="filter_today" domain="[('checkin_datetime', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0)))]"/>
                <filter string="Emergency" name="filter_emergency" domain="[('priority', '=', 'emergency')]"/>
                <filter string="Urgent" name="filter_urgent" domain="[('priority', '=', 'urgent')]"/>
                <separator/>
                <filter string="Active Queue" name="filter_active_queue" domain="[('state', 'not in', ['done', 'cancelled', 'void'])]"/>
                <group>
                    <filter string="Status" name="groupby_state" context="{'group_by': 'state'}"/>
                    <filter string="Doctor" name="groupby_doctor" context="{'group_by': 'doctor_id'}"/>
                    <filter string="Department" name="groupby_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Priority" name="groupby_priority" context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hospital_visit_action" model="ir.actions.act_window">
        <field name="name">Visits</field>
        <field name="res_model">hospital.visit</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="hospital_visit_view_search"/>
        <field name="context">{'search_default_filter_active_queue': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register the first visit
            </p>
        </field>
    </record>

</odoo>
