<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hospital_audit_log_view_form" model="ir.ui.view">
        <field name="name">hospital.audit.log.view.form</field>
        <field name="model">hospital.audit.log</field>
        <field name="arch" type="xml">
            <form string="Audit Log Entry" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="res_model"/>
                            <field name="res_id"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="action"/>
                            <field name="timestamp"/>
                        </group>
                    </group>
                    <group string="Field Changes">
                        <field name="field_changes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hospital_audit_log_view_list" model="ir.ui.view">
        <field name="name">hospital.audit.log.view.list</field>
        <field name="model">hospital.audit.log</field>
        <field name="arch" type="xml">
            <list string="Audit Log" create="0" edit="0" delete="0">
                <field name="timestamp"/>
                <field name="res_model"/>
                <field name="res_id"/>
                <field name="action"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="hospital_audit_log_view_search" model="ir.ui.view">
        <field name="name">hospital.audit.log.view.search</field>
        <field name="model">hospital.audit.log</field>
        <field name="arch" type="xml">
            <search string="Search Audit Log">
                <field name="res_model"/>
                <field name="user_id"/>
                <field name="action"/>
                <group>
                    <filter string="Model" name="groupby_model" context="{'group_by': 'res_model'}"/>
                    <filter string="User" name="groupby_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Action" name="groupby_action" context="{'group_by': 'action'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hospital_audit_log_action" model="ir.actions.act_window">
        <field name="name">Audit Log</field>
        <field name="res_model">hospital.audit.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hospital_audit_log_view_search"/>
    </record>

</odoo>
