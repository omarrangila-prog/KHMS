<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hospital_patient_id_card_paperformat" model="report.paperformat">
        <field name="name">Patient ID Card</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_height">54</field>
        <field name="page_width">86</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">3</field>
        <field name="margin_bottom">3</field>
        <field name="margin_left">3</field>
        <field name="margin_right">3</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="hospital_patient_id_card_report" model="ir.actions.report">
        <field name="name">Patient ID Card</field>
        <field name="model">hospital.patient</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hospital_base.hospital_patient_id_card_template</field>
        <field name="report_file">hospital_base.hospital_patient_id_card_template</field>
        <field name="binding_model_id" ref="model_hospital_patient"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="hospital_patient_id_card_paperformat"/>
        <field name="print_report_name">'Patient ID Card - %s' % (object.patient_code)</field>
    </record>

</odoo>
